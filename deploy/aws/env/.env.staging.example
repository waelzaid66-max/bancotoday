###############################################################################
# BANCO API — STAGING template. Same shape as production, but TEST integration
# keys + a separate database + relaxed logging. Never commit real values.
###############################################################################
NODE_ENV=production            # staging runs the production build
PORT=8080
DATABASE_URL=postgresql://USER:PASS@STAGING-RDS:5432/banco_staging   # [REQUIRED] separate DB
SESSION_SECRET=                # [REQUIRED]
PAYMENT_CONFIG_ENCRYPTION_KEY= # [REQUIRED] separate key from prod

CLERK_SECRET_KEY=sk_test_...   # test instance in staging
CLERK_PUBLISHABLE_KEY=pk_test_...

CORS_ALLOWED_ORIGINS=https://staging.example.com
PUBLIC_API_BASE_URL=https://api.staging.example.com
PUBLIC_APP_URL=https://staging.example.com
ADMIN_EMAILS=ops@example.com

OBJECT_STORAGE_PROVIDER=s3
AWS_REGION=eu-central-1
S3_BUCKET=banco-media-staging
PUBLIC_OBJECT_SEARCH_PATHS=/public
PRIVATE_OBJECT_DIR=/private

OPENAI_API_KEY=                # optional in staging
OPENAI_MODEL=gpt-4o-mini
RESEND_API_KEY=
EMAIL_FROM=BANCO Staging <no-reply@staging.example.com>

PAYMOB_MODE=test               # NEVER live in staging
PAYMOB_API_BASE=https://accept.paymob.com
PAYMOB_PUBLIC_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_IDS=

LOG_LEVEL=debug                # louder in staging
ERROR_ALERT_WEBHOOK=
CRON_TIMEZONE=Africa/Cairo
