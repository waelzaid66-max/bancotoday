###############################################################################
# BANCO consumer web (banco-web) — STAGING template
# Copy to CI/CD secrets or bake as Docker build-args. Never commit real keys.
#
# Safe defaults: live search/map OFF until API FRESH + mobile regression PASS.
# Website outage must NOT affect mobile — this service is CDN/Container isolated.
###############################################################################

NEXT_PUBLIC_SITE_URL=https://staging-web.example.com
NEXT_PUBLIC_API_URL=https://staging-api.example.com

# Linked surfaces (optional — footer/nav deep links)
NEXT_PUBLIC_MARKET_URL=https://staging.example.com/dealer-os
NEXT_PUBLIC_ADMIN_URL=https://staging.example.com/admin-os
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Clerk (required for /workspace and /saved on staging)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PROXY_URL=

# Feature flags — first staging smoke: LIVE/MAP/MARKET off; enable one-by-one after smoke
NEXT_PUBLIC_SEARCH_ENABLED=true
NEXT_PUBLIC_WEB_SEARCH_LIVE=false
NEXT_PUBLIC_WEB_SEARCH_MAP=false
NEXT_PUBLIC_WEB_MARKET_COPY=false
NEXT_PUBLIC_SEARCH_ANALYTICS_MODE=debug
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Docker standalone build
NEXT_STANDALONE=true

# Phase 6 — runtime plug (compose/k8s env). false unplugs site without rebuild.
WEB_PLUG_ENABLED=true

# After first smoke green, optional staging experiments:
# NEXT_PUBLIC_WEB_SEARCH_LIVE=true
# NEXT_PUBLIC_WEB_MARKET_COPY=true

# Landing artifact (nginx root) — redirect hub to consumer web
VITE_WEB_URL=https://staging-web.example.com

