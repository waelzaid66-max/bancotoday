###############################################################################
# BANCO API — LOCAL DEVELOPMENT template. Points at a local Postgres and uses
# TEST integration keys. Copy to a private .env and source it before running.
###############################################################################
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/banco_test   # local portable PG (port 5433)
SESSION_SECRET=dev-only-not-a-secret
PAYMENT_CONFIG_ENCRYPTION_KEY=dev-only-32-bytes-xxxxxxxxxxxxxxx

CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
PUBLIC_API_BASE_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:5175
ADMIN_EMAILS=you@example.com

# Local dev may keep using whatever storage is wired; on AWS this becomes S3.
OBJECT_STORAGE_PROVIDER=
AWS_REGION=
S3_BUCKET=
PUBLIC_OBJECT_SEARCH_PATHS=/public
PRIVATE_OBJECT_DIR=/private

OPENAI_API_KEY=                # optional; assistant is off if unset
OPENAI_MODEL=gpt-4o-mini
RESEND_API_KEY=
EMAIL_FROM=BANCO Dev <dev@example.com>

PAYMOB_MODE=test
PAYMOB_API_BASE=https://accept.paymob.com
PAYMOB_PUBLIC_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_IDS=

LOG_LEVEL=debug
CRON_TIMEZONE=Africa/Cairo
