###############################################################################
# BANCO API — PRODUCTION environment template.  COPY, fill, and store the real
# file in AWS SSM Parameter Store / Secrets Manager. NEVER commit real values.
#
# Legend:  [REQUIRED] server won't work without it · [feature] gates one feature
#          · [public] safe to expose (baked into web builds)
###############################################################################

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080                                  # [REQUIRED] platform sets this; app throws without it
DATABASE_URL=postgresql://USER:PASS@RDS-ENDPOINT:5432/banco   # [REQUIRED] AWS RDS PostgreSQL 16 (needs pg_trgm)
SESSION_SECRET=                            # [REQUIRED] long random string (>=32 bytes)
PAYMENT_CONFIG_ENCRYPTION_KEY=             # [REQUIRED] 32-byte key; encrypts stored payment provider config

# ── Authentication (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...               # [REQUIRED] production instance secret
CLERK_PUBLISHABLE_KEY=pk_live_...          # [public] server-side reference of the publishable key

# ── Networking / CORS ────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://banco.example.com,https://admin.example.com  # [REQUIRED] comma-separated browser origins
PUBLIC_API_BASE_URL=https://api.example.com     # [feature] absolute API base for SEO/emails/links
PUBLIC_APP_URL=https://banco.example.com         # [feature] absolute web app base
ADMIN_EMAILS=ops@example.com                     # [feature] bootstrap admin allowlist

# ── Object storage (S3) — see reports/06 REQUIRED-CHANGE ─────────────────────
# The current code targets Replit Object Storage via a local sidecar; on AWS an
# S3 adapter is required. These are the variables that adapter will read.
OBJECT_STORAGE_PROVIDER=s3
AWS_REGION=eu-central-1
S3_BUCKET=banco-media-prod
PUBLIC_OBJECT_SEARCH_PATHS=/public         # search path(s) for public objects
PRIVATE_OBJECT_DIR=/private                # base dir/prefix for private objects
# On EC2/ECS use an IAM role for S3 (no keys). Only for non-AWS hosts:
# AWS_ACCESS_KEY_ID=  /  AWS_SECRET_ACCESS_KEY=

# ── AI (OpenAI) ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                       # [feature] AI assistant; feature off if unset / DUMMY rejected
OPENAI_MODEL=gpt-4o-mini                    # [feature] optional model override
OPENAI_TIMEOUT_MS=30000                     # [feature] request timeout (1s–120s; default 30s)
OPENAI_MAX_RETRIES=1                        # [feature] SDK retries (0–5; default 1)
OPENAI_MAX_COMPLETION_TOKENS=2048           # [feature] cost cap (256–8192; default 2048)
# AI_INTEGRATIONS_OPENAI_BASE_URL=          # LEAVE UNSET on AWS (Replit-only modelfarm proxy)
# AI_INTEGRATIONS_OPENAI_API_KEY=           # Replit-only alias; not used on AWS

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                       # [feature] transactional email; off if unset
EMAIL_FROM=BANCO <no-reply@example.com>     # [feature] verified sender

# ── Payments (Paymob) ────────────────────────────────────────────────────────
PAYMOB_MODE=live                            # [feature] test|live
PAYMOB_API_BASE=https://accept.paymob.com
PAYMOB_PUBLIC_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_HMAC_SECRET=                         # verifies webhook authenticity
PAYMOB_INTEGRATION_IDS=                     # comma-separated integration ids

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info                              # trace|debug|info|warn|error
LOG_DIR=                                    # leave empty → stdout only (CloudWatch captures it)
ERROR_ALERT_WEBHOOK=                        # [feature] Slack/webhook for error alerts
CRON_TIMEZONE=Africa/Cairo                  # scheduled-jobs timezone

# ── DO NOT SET on AWS (Replit-only; presence changes behaviour) ──────────────
# REPLIT_DEPLOYMENT= / REPLIT_DEV_DOMAIN= / REPLIT_DOMAINS=
