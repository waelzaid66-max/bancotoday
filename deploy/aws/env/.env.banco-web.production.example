###############################################################################
# BANCO consumer web (banco-web) — PRODUCTION soft-launch template
# Copy to secrets / deploy env. Never commit real keys.
#
# Soft-launch defaults: LIVE/MAP/MARKET OFF. Plug ON.
# Website outage must NOT affect mobile — isolated CDN/container only.
###############################################################################

NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_API_URL=https://api.example.com

# Linked surfaces (optional)
NEXT_PUBLIC_MARKET_URL=https://www.example.com/dealer-os
NEXT_PUBLIC_ADMIN_URL=https://www.example.com/admin-os
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Clerk (required for /workspace and /saved)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_PROXY_URL=

# Soft-launch flags — keep false until staging soak is green
NEXT_PUBLIC_SEARCH_ENABLED=true
NEXT_PUBLIC_WEB_SEARCH_LIVE=false
NEXT_PUBLIC_WEB_SEARCH_MAP=false
NEXT_PUBLIC_WEB_MARKET_COPY=false
NEXT_PUBLIC_SEARCH_ANALYTICS_MODE=off
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

NEXT_STANDALONE=true

# Runtime plug — false unplugs without rebuild (see WEBSITE-PLUG-DETACH-5MIN-AR.md)
WEB_PLUG_ENABLED=true

# Landing hub redirect (optional)
VITE_WEB_URL=https://www.example.com
