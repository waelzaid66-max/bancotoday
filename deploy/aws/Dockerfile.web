# syntax=docker/dockerfile:1.7
###############################################################################
# BANCO web surfaces — static build + Nginx (AWS)
#
# Builds the three Vite SPAs (admin-os, dealer-os, landing) and serves them from
# a single Nginx that also reverse-proxies /api to the API container. One origin,
# path-routed — the cheapest production topology (no extra load balancers).
#
# Vite reads VITE_* at BUILD time, so the public URLs are baked in as build args.
#
# Build context = the REPOSITORY ROOT:
#   docker build -f deploy/aws/Dockerfile.web \
#     --build-arg VITE_CLERK_PUBLISHABLE_KEY=pk_live_... \
#     --build-arg VITE_API_BASE_URL=https://api.example.com \
#     -t banco-web .
###############################################################################

FROM node:24-bookworm-slim AS builder
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

# Build-time public config (safe to bake — publishable keys + public URLs only).
ARG VITE_CLERK_PUBLISHABLE_KEY=""
ARG VITE_API_BASE_URL=""
ARG VITE_MARKET_URL=""
ARG VITE_ADMIN_URL=""
ARG VITE_APP_ANDROID_URL=""
ARG VITE_APP_IOS_URL=""
ENV VITE_CLERK_PUBLISHABLE_KEY=$VITE_CLERK_PUBLISHABLE_KEY \
    VITE_API_BASE_URL=$VITE_API_BASE_URL \
    VITE_MARKET_URL=$VITE_MARKET_URL \
    VITE_ADMIN_URL=$VITE_ADMIN_URL \
    VITE_APP_ANDROID_URL=$VITE_APP_ANDROID_URL \
    VITE_APP_IOS_URL=$VITE_APP_IOS_URL

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY lib ./lib
COPY artifacts/admin-os/package.json ./artifacts/admin-os/package.json
COPY artifacts/dealer-os/package.json ./artifacts/dealer-os/package.json
COPY artifacts/landing/package.json ./artifacts/landing/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile
COPY . .
RUN pnpm --filter @workspace/admin-os --filter @workspace/dealer-os --filter @workspace/landing run build

# ---- serve ------------------------------------------------------------------
FROM nginx:1.27-alpine AS runner
RUN rm -rf /usr/share/nginx/html/*
# Each SPA under its own path prefix (see nginx.conf try_files roots).
COPY --from=builder /app/artifacts/landing/dist    /usr/share/nginx/html/
COPY --from=builder /app/artifacts/dealer-os/dist  /usr/share/nginx/html/market/
COPY --from=builder /app/artifacts/admin-os/dist   /usr/share/nginx/html/admin/
COPY deploy/aws/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1/nginx-health || exit 1
