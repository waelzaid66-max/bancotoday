# GCP Cloud Run — staging (no secrets committed)
# Use Secret Manager in deploy; values here are placeholders only.

NODE_ENV=production
PORT=8080
TZ=UTC

DATABASE_URL=postgresql://USER:PASS@/banco_staging?host=/cloudsql/PROJECT:REGION:INSTANCE

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

OBJECT_STORAGE_PROVIDER=s3
S3_BUCKET=banco-staging-uploads
AWS_REGION=auto
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=debug

PAYMOB_ENABLED=false
