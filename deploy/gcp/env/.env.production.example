# GCP Cloud Run — production env template (no secrets committed).
# Map each value to Secret Manager and inject at deploy time.

NODE_ENV=production
PORT=8080
TZ=UTC

DATABASE_URL=postgresql://USER:PASS@/banco?host=/cloudsql/PROJECT:REGION:INSTANCE

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Object storage — API supports ONLY: s3 | replit (default).
# There is no OBJECT_STORAGE_PROVIDER=gcs value.
#
# Option A (Replit host / existing sidecar): omit provider or set replit
# OBJECT_STORAGE_PROVIDER=replit
#
# Option B (GCP Cloud Storage via S3 interoperability / HMAC):
OBJECT_STORAGE_PROVIDER=s3
AWS_REGION=auto
S3_BUCKET=
# Optional if using GCS XML API / custom endpoint — wire in S3 client when needed:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=1
OPENAI_MAX_COMPLETION_TOKENS=2048
RESEND_API_KEY=

# Paymob — disabled until admin wave B5
PAYMOB_ENABLED=false

# Observability (optional — structured logs always on stdout)
LOG_LEVEL=info
ERROR_ALERT_WEBHOOK=
