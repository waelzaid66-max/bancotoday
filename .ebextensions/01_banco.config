# Elastic Beanstalk configuration for the BANCO API (Docker / Amazon Linux 2023).
#
# The whole API is served under /api, so the load balancer must health-check
# /api/healthz (a plain GET / would 404). We also raise the command timeout so
# the on-instance Docker build (pnpm install + esbuild for the monorepo) has room
# to finish, and set NODE_ENV. Secrets (DATABASE_URL, CLERK_SECRET_KEY, …) are
# NOT here — set those as Environment Properties in the EB console / eb setenv.

option_settings:
  # ALB target-group health check → the API's liveness endpoint.
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /api/healthz
    Port: "80"
    Protocol: HTTP
    MatcherHTTPCode: "200"
    HealthyThresholdCount: "3"
    UnhealthyThresholdCount: "5"

  # Give the on-instance image build enough time (monorepo install + bundle).
  aws:elasticbeanstalk:command:
    Timeout: "1800"
    DeploymentPolicy: RollingWithAdditionalBatch

  # Non-secret app config. Real secrets go in Environment Properties (console).
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    CRON_TIMEZONE: Africa/Cairo
    LOG_LEVEL: info
