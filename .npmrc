auto-install-peers=false
strict-peer-dependencies=false
ignore-workspace-root-check=true
confirm-modules-purge=false
# Expo Metro in banco-mobile watches the monorepo root. Prefer a flat
# node_modules layout so Expo / react-navigation transitives resolve for
# local export and EAS. Hierarchical lookup remains enabled in metro.config.js
# as a safety net when packages live under package-local or .pnpm paths.
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern[]=@react-navigation/*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=expo
public-hoist-pattern[]=expo-*
public-hoist-pattern[]=react-native*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=fbjs
public-hoist-pattern[]=styleq
