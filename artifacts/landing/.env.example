# BANCO Landing — copy to .env for local dev (Vite)

# Banco Market (dealer-os) base URL, e.g. https://banco.example.com/market/
VITE_MARKET_URL=

# Consumer browse site (banco-web). When set, landing root redirects to {VITE_WEB_URL}/directory (W8).
VITE_WEB_URL=

# Admin panel base URL, e.g. https://banco.example.com/admin/
VITE_ADMIN_URL=

# Mobile app store links
VITE_APP_ANDROID_URL=
VITE_APP_IOS_URL=
