# Copy to .secrets/local.env (gitignored) — never commit real values.
# Load: node scripts/load-local-secrets.mjs  (flags only)

BANCO_API_URL=https://banco-ca-oom.replit.app

# Postgres — same DB as Replit/staging API
DATABASE_URL=

# Clerk session JWT (primary test user) — required for upload smoke steps 3–8
# How: sign in on staging/preview app → DevTools Network → Authorization header on /v1/* 
#   OR Clerk Dashboard → Users → impersonate → copy session token (short-lived)
CLERK_BEARER_TOKEN=

# Optional second user for IDOR step 7
CLERK_BEARER_TOKEN_OTHER=

# Server keys (Replit Secrets — not needed on PC unless running api-server locally)
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=

# EAS CLI
EXPO_TOKEN=

# GitHub CLI (optional) — rotate immediately if exposed in chat/logs
# GH_TOKEN=
